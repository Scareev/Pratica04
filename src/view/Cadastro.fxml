<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="gui.CadastroController"
      spacing="10" alignment="TOP_CENTER"
      style="-fx-padding: 20; -fx-background-color: #f5f5f5;">

    <Label text="Cadastro de Pessoa"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="8">
        <padding><Insets top="10" bottom="10"/></padding>

        <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nomeField" promptText="Nome completo" prefWidth="300" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="CPF:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="cpfField" promptText="000.000.000-00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Data de Nascimento:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dataNascimentoPicker" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Telefone:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="telefoneField" promptText="(00) 00000-0000" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Endereço:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="enderecoField" promptText="Rua, número" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Bairro:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="bairroField" promptText="Bairro" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Cidade:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="cidadeField" promptText="Cidade" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

        <Label text="Estado:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
        <TextField fx:id="estadoField" promptText="Ex: SP" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

        <Label text="CEP:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
        <TextField fx:id="cepField" promptText="00000-000" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

    </GridPane>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Cadastrar"  onAction="#onCadastrar"
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-pref-width: 100;"/>
    </HBox>

</VBox>