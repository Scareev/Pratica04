<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" maxWidth="300" spacing="12" style="-fx-padding: 40; -fx-background-color: #d5eef0;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gui.LoginController">

    <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Entrar" textFill="#130a4a">
      <font>
         <Font name="SansSerif Regular" size="12.0" />
      </font></Label>

    <TextField fx:id="nomeField" promptText="Nome" style="-fx-background-radius: 15px; -fx-border-color: #a5d2fa; -fx-border-radius: 15px; -fx-border-width: 2px;" />
    <TextField fx:id="cpfField" promptText="CPF" style="-fx-background-radius: 15px; -fx-border-color: #a5d2fa; -fx-border-radius: 15px; -fx-border-width: 2px;" />

    <Button maxWidth="Infinity" onAction="#onLogin" style="-fx-background-radius: 15px; -fx-background-color: #a5d2fa;" text="Entrar" />

    <Hyperlink onAction="#onEsqueceuSenha" style="-fx-font-size: 12px;" text="Ainda não tem cadastro? Cadastre-se" />

</VBox>
